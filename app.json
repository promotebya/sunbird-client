{
  "expo": {
    "name": "LovePointsApp",
    "slug": "lovepointsapp",
    "scheme": "lovepointsapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/icon.png",
    "splash": {
      "image": "assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.promotebya.lovepointsapp",
      "supportsTablet": false
    },
    "android": {
      "package": "com.promotebya.lovepointsapp",
      "adaptiveIcon": {
        "foregroundImage": "assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "assets/notification-icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "jsEngine": "hermes"
  }
}
